# =============================================================================
# Voice Negotiation Level — Configuration
# =============================================================================
# Local-only for now. The main my_project Flask app loads these values via
# python-dotenv at routes.py import time.
# =============================================================================

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
# Both VOX and Judge use the same model (3B) so Ollama keeps a single set
# of weights in RAM. Acceptable on 16 GB Apple Silicon.
OLLAMA_MODEL_VOX=qwen2.5:3b-instruct
OLLAMA_MODEL_JUDGE=qwen2.5:3b-instruct

# Timeout for Ollama calls (seconds). 300s leaves headroom for cold starts.
OLLAMA_TIMEOUT=300

# LLM temperature (0.0 = deterministic, 1.0 = creative).
VOX_TEMPERATURE=0.7
JUDGE_TEMPERATURE=0.2

# --- STT (mlx-whisper) ---
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_LANGUAGE=en

# --- TTS (Piper) ---
PIPER_VOICE_PATH=assets/voices/en_US-amy-medium.onnx
# Global pacing multiplier on top of the per-mood profiles in core/tts.py.
PIPER_LENGTH_SCALE=1.0

# --- Game ---
MAX_TURNS=30
# Threshold (0–100) for a Release Condition to be "satisfied", compared
# against the MERGED score (avg of VOX + Judge). 20 = near-trivial demo,
# 40 = reasonable challenge, 70–75 = strict.
CONDITION_THRESHOLD=20
# Sliding-window size for history passed to VOX/Judge.
MAX_HISTORY_MESSAGES=6

# --- Logging ---
LOG_LEVEL=INFO

# --- UI ---
DEBUG_PANEL=true
