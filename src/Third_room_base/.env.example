# =============================================================================
# Escape Room Livello 3 - Configurazione
# =============================================================================
# Copia questo file in `.env` e adatta i valori se necessario.
# I default sono pensati per macOS Apple Silicon con setup standard.
# =============================================================================

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_VOX=qwen2.5:7b-instruct
OLLAMA_MODEL_JUDGE=qwen2.5:3b-instruct

# Timeout per chiamate Ollama (secondi)
OLLAMA_TIMEOUT=60

# Temperatura LLM (0.0 = deterministico, 1.0 = creativo)
# VOX un po' caldo per personalità, Judge freddo per oggettività
VOX_TEMPERATURE=0.7
JUDGE_TEMPERATURE=0.2

# --- STT (mlx-whisper) ---
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_LANGUAGE=it

# --- TTS (Piper) ---
PIPER_VOICE_PATH=assets/voices/it_IT-paola-medium.onnx
# Velocità di sintesi (1.0 = normale, <1.0 più veloce, >1.0 più lento)
PIPER_LENGTH_SCALE=1.0

# --- Game ---
# Numero massimo di turni prima del timeout narrativo
MAX_TURNS=30
# Soglia (0-100) per considerare una Condizione di Rilascio "soddisfatta"
CONDITION_THRESHOLD=75

# --- Logging ---
LOG_LEVEL=INFO
# Salva trascrizioni delle sessioni in logs/sessions/ per debug
SAVE_SESSION_LOGS=true

# --- UI ---
# Mostra trascrizione testuale (utile in sviluppo, opzionale in demo)
SHOW_TRANSCRIPT=true
# Mostra stato interno (punteggi, fase) - solo dev, OFF in demo
DEBUG_PANEL=true
