# =============================================================================
# Escape Room Level 3 — Configuration
# =============================================================================
# Copy this file to `.env` and adjust the values if needed.
# Defaults are tuned for macOS Apple Silicon with a standard setup.
# =============================================================================

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_VOX=qwen2.5:7b-instruct
OLLAMA_MODEL_JUDGE=qwen2.5:3b-instruct

# Timeout for Ollama calls (seconds). 300s leaves headroom for long-history
# turns on 16GB Apple Silicon. Warm short turns return in 3-10s.
OLLAMA_TIMEOUT=300

# LLM temperature (0.0 = deterministic, 1.0 = creative)
# VOX a bit warm for personality, Judge cold for objectivity
VOX_TEMPERATURE=0.7
JUDGE_TEMPERATURE=0.2

# --- STT (mlx-whisper) ---
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_LANGUAGE=en

# --- TTS (Piper) ---
PIPER_VOICE_PATH=assets/voices/en_US-amy-medium.onnx
# Synthesis speed (1.0 = normal, <1.0 faster, >1.0 slower)
PIPER_LENGTH_SCALE=1.0

# --- Game ---
# Maximum number of turns before narrative timeout
MAX_TURNS=30
# Threshold (0–100) for a Release Condition to be considered "satisfied"
CONDITION_THRESHOLD=75
# Sliding-window size for history passed to VOX/Judge (msgs, not turns).
# 6 = last 3 exchanges. Lower if VOX timeouts persist on 16GB Mac.
MAX_HISTORY_MESSAGES=6

# --- Logging ---
LOG_LEVEL=INFO
# Save session transcripts in logs/sessions/ for debugging
SAVE_SESSION_LOGS=true

# --- UI ---
# Show transcript text (useful in development, optional in demo)
SHOW_TRANSCRIPT=true
# Show internal state (scores, phase) — dev only, OFF in demo
DEBUG_PANEL=true

# --- Atmosphere ---
# Looping ambient drone in the background. Volume 0.0–1.0.
AMBIENT_DRONE=true
AMBIENT_DRONE_VOLUME=0.15
